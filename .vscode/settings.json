{
  "cSpell.userWords": ["clsx", "xsmall"],
  "css.validate": false,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.codeLens": true,
  "editor.accessibilitySupport": "off",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.format.oxc": "always",
    "source.addMissingImport": "explicit",
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit"
  },
  "editor.dragAndDrop": false,
  "editor.fontSize": 13,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": false,
  "editor.formatOnSaveMode": "file",
  "editor.formatOnType": true,
  "editor.lineNumbers": "on",
  "editor.minimap.maxColumn": 90,
  "editor.minimap.showSlider": "always",
  "editor.minimap.size": "fit",
  "editor.quickSuggestions": {
    "strings": true
  },
  "editor.renderControlCharacters": true,
  "editor.renderWhitespace": "boundary",
  "editor.rulers": [80],
  "editor.suggestSelection": "first",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "keyword.other.dotenv",
        "settings": {
          "foreground": "#FF000000"
        }
      }
    ]
  },
  "editor.wordWrap": "on",
  "explorer.confirmDragAndDrop": false,
  "explorer.incrementalNaming": "smart",
  "files.associations": {
    ".env*": "dotenv"
  },
  "files.autoSave": "onFocusChange",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "github.copilot.nextEditSuggestions.enabled": true,
  "gitlens.launchpad.indicator.enabled": false,
  "gitlens.rebaseEditor.ordering": "asc",
  "gitlens.views.scm.grouped.views": {
    "branches": true,
    "commits": true,
    "contributors": true,
    "launchpad": true,
    "remotes": true,
    "repositories": false,
    "searchAndCompare": false,
    "stashes": true,
    "tags": true,
    "worktrees": true
  },
  "hediet.vscode-drawio.appearance": "dark",
  "hediet.vscode-drawio.codeLinkActivated": false,
  "hediet.vscode-drawio.resizeImages": null,
  "hediet.vscode-drawio.theme": "kennedy",
  "less.validate": false,
  "markdown-pdf.headerTemplate": "<span class='title' style='display: none;'></span>",
  "scss.validate": false,
  "terminal.integrated.env.osx": {
    "Q_NEW_SESSION": "1"
  },
  "terminal.integrated.fontFamily": "Hack Nerd Font Mono",
  "workbench.colorTheme": "Iceberg",
  "workbench.editor.enablePreview": false,
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "chat.viewSessions.orientation": "stacked",
  "githubPullRequests.pullBranch": "never",
  "terraform.codelens.referenceCount": true,
  "explorer.compactFolders": false,
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true
  },
  "explorer.confirmDelete": false,
  "githubPullRequests.createOnPublishBranch": "never",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilotcli:",
  "js/ts.experimental.useTsgo": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.referencesCodeLens.enabled": true
}
